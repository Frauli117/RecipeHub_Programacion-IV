# Plantilla de variables de entorno para RecipeHub.
# Copiar a .env y reemplazar con valores reales:  cp .env.example .env
# El archivo .env real NUNCA se sube al repositorio (está en .gitignore).

# --- MongoDB (contenedor mongo) ---
MONGO_USER=admin
MONGO_PASS=cambia_esta_clave

# --- Conexión de la API a MongoDB ---
# El host debe ser "mongo" (nombre del servicio en docker-compose.yml).
MONGO_URI=mongodb://admin:cambia_esta_clave@mongo:27017/recipehub?authSource=admin

# --- Autenticación ---
# Generar uno aleatorio, por ejemplo:  openssl rand -hex 32
JWT_SECRET=reemplaza_con_un_string_largo_y_aleatorio

# --- API (opcional) ---
PORT=4000
